# Required. Franklin uses PostgreSQL via Prisma; there is no SQLite fallback.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/franklin"

# Authentication mode: "mock" (demo accounts) or "strict" (OIDC provider).
FRANKLIN_AUTH_MODE="mock"

# Token encryption and session signing secret. Required in production.
# In development, a weak fallback is used if omitted.
FRANKLIN_TOKEN_SECRET="replace-this-with-a-long-random-secret"

# Optional: override session signing secret (falls back to TOKEN_SECRET).
# FRANKLIN_SESSION_SECRET=""

# Secret rotation: set previous secrets during rotation to keep old
# sessions/tokens valid. Remove after the rotation window (e.g., 8 hours).
# FRANKLIN_TOKEN_SECRET_PREVIOUS=""
# FRANKLIN_SESSION_SECRET_PREVIOUS=""

# --- OIDC (required when FRANKLIN_AUTH_MODE="strict") ---
# FRANKLIN_OIDC_ISSUER="https://accounts.google.com"
# FRANKLIN_OIDC_CLIENT_ID=""
# FRANKLIN_OIDC_CLIENT_SECRET=""
# FRANKLIN_OIDC_SCOPES="openid email profile"
# FRANKLIN_BASE_URL must include basePath when deployed under a subpath.
# Local:      http://localhost:3000/franklin
# Production: https://onebridgestalwart.com/franklin
# FRANKLIN_BASE_URL="http://localhost:3000/franklin"

# Comma-separated emails that receive ADMIN role via OIDC. Others get PARTNER.
# FRANKLIN_ADMIN_EMAILS="admin@example.com"

# --- Rate limiting (optional, falls back to in-memory) ---
# FRANKLIN_UPSTASH_REDIS_URL=""
# FRANKLIN_UPSTASH_REDIS_TOKEN=""

# --- Email notifications (MailerSend) ---
# MAILERSEND_API_KEY=""
# EMAIL_FROM="Samuel | Onebridge Stalwart <samuel@onebridgestalwart.com>"
# EMAIL_REPLY_TO="samuel@onebridgestalwart.com"
# EMAIL_INTERNAL_NOTIFICATIONS="samuel@onebridgestalwart.com"
# MAILERSEND_WEBHOOK_SECRET=""
