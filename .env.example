# Required. Franklin uses PostgreSQL via Prisma; there is no SQLite fallback.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/franklin"

# Supported today only in mock mode. Keep "mock" for local internal use.
FRANKLIN_AUTH_MODE="mock"

# Recommended. If omitted, token encryption falls back to a weak dev secret.
FRANKLIN_TOKEN_SECRET="replace-this-with-a-long-random-secret"
